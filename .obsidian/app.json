    ".claude",
    ".agents",
    ".cursor",
    ".git",
    ".rules",
    ".gemini",
    ".playwright-mcp",
    ".vscode",
    "tmp/",
    "media/raw/",
    "media/exports/",
    "remotion-content",
    "skills/gws-",
    "gritly-fix"
