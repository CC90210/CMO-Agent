{
  "monoFontFamily": "JetBrains Mono, Fira Code, Consolas, monospace",
  "useMarkdownLinks": false,
  "showUnsupportedFiles": false,
  "newFileLocation": "folder",
  "newFileFolderPath": "memory/daily",
